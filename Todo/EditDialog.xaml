<Window x:Class="WinKit.Todo.EditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑待办"
        Width="240"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <!-- 与主窗口一致：圆角 + 半透明白色背景 -->
    <Border Background="#F2FFFFFF"
            CornerRadius="10"
            BorderBrush="#44000000"
            BorderThickness="1">
        <StackPanel Margin="14,12">

            <!-- 标题行：可拖动 -->
            <Grid x:Name="DlgTitleBar"
                  MouseLeftButtonDown="DlgTitleBar_MouseLeftButtonDown"
                  Margin="0,0,0,10">
                <TextBlock Text="编辑待办"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#555"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Enter 确认 · Esc 取消"
                           FontSize="10"
                           Foreground="#999"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- 输入框：使用与主窗口一致的样式 -->
            <TextBox x:Name="InputBox"
                     Style="{StaticResource InlineTextBox}"
                     Margin="0,0,0,12"
                     KeyDown="InputBox_KeyDown"
                     ToolTip="Enter 确认 / Esc 取消"/>
        </StackPanel>
    </Border>
</Window>
