<Window x:Class="WinKit.Common.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 WinKit" Width="280" Height="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Deactivated="Window_Deactivated">

    <Border Background="#D9F5F5F5"
            CornerRadius="10"
            BorderBrush="#1A000000"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏：拖动 + 关闭 -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="关于"
                           VerticalAlignment="Center"
                           Margin="14,0"
                           FontSize="11"
                           Foreground="#666"/>
                <Button x:Name="CloseBtn"
                        Content="✕"
                        Style="{StaticResource TitleBarBtn}"
                        HorizontalAlignment="Right"
                        Margin="0,0,4,0"
                        Click="CloseBtn_Click"/>
            </Grid>

            <!-- 关于内容 -->
            <Grid Grid.Row="1" Margin="20,10,20,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 应用名 & 版本 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock Text="WinKit" FontSize="18" FontWeight="Bold" Foreground="#222"/>
                    <TextBlock x:Name="VersionText" Text="v1.0.0" FontSize="12" Foreground="#888" Margin="6,0,0,2" VerticalAlignment="Bottom"/>
                </StackPanel>

                <!-- 信息表格 -->
                <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="作者:" Foreground="#777" FontSize="12" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="li5bo5" Foreground="#222" FontSize="12" FontWeight="SemiBold"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="项目地址:" Foreground="#777" FontSize="12" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" x:Name="LinkText" 
                               Text="github.com/li5bo5/WinKit" 
                               Foreground="#0066CC" 
                               FontSize="12" 
                               Cursor="Hand"
                               TextDecorations="Underline"
                               MouseEnter="LinkText_MouseEnter"
                               MouseLeave="LinkText_MouseLeave"
                               MouseLeftButtonDown="LinkText_MouseLeftButtonDown"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="开源协议:" Foreground="#777" FontSize="12" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="AGPL-3.0" ToolTip="GNU Affero General Public License v3.0" Foreground="#222" FontSize="12" FontWeight="SemiBold"/>
                </Grid>

                <!-- 版权标语 -->
                <TextBlock Grid.Row="2" 
                           Text="© 2026 li5bo5. All Rights Reserved." 
                           HorizontalAlignment="Center" 
                           FontSize="10" 
                           Foreground="#999"/>
            </Grid>
        </Grid>
    </Border>
</Window>
