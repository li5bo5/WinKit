<Window x:Class="WinKit.Clipboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WinKit.Clipboard.Models"
        Title="Clipboard" Width="300" Height="400"
        MinWidth="260" MinHeight="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Deactivated="Window_Deactivated"
        ResizeMode="CanResize">

    <!-- 主容器：圆角边框 + 60% 不透明白色背景 (#99FFFFFF) -->
    <Border x:Name="RootBorder"
            Background="#CCFFFFFF"
            CornerRadius="10"
            BorderBrush="#22000000"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════
                 标题栏：拖动 + 关闭按钮
            ══════════════════════════════════════════ -->
            <Grid Grid.Row="0" x:Name="TitleBar"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  Background="Transparent">

                <TextBlock Text="Clipboard"
                           VerticalAlignment="Center"
                           Margin="14,0"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#333"/>

                <Button x:Name="CloseBtn"
                        Content="✕"
                        Style="{StaticResource TitleBarBtn}"
                        HorizontalAlignment="Right"
                        Margin="0,0,4,0"
                        Opacity="1"
                        Click="CloseBtn_Click"
                        ToolTip="隐藏"/>
            </Grid>

            <!-- ══════════════════════════════════════════
                 内容列表
            ══════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <ListBox x:Name="ClipboardList"
                         Background="Transparent"
                         BorderThickness="0"
                         VirtualizingStackPanel.IsVirtualizing="True"
                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                         ScrollViewer.CanContentScroll="True"
                         FocusVisualStyle="{x:Null}"
                         IsTabStop="False"
                         KeyDown="ClipboardList_KeyDown"
                         MouseDoubleClick="ClipboardList_MouseDoubleClick">

                    <ListBox.Template>
                        <ControlTemplate TargetType="ListBox">
                            <ScrollViewer Style="{StaticResource NarrowScrollViewer}"
                                          Focusable="False">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </ControlTemplate>
                    </ListBox.Template>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ListBoxItem_PreviewMouseLeftButtonDown"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="itemBd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Margin="6,2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="itemBd" Property="Background" Value="#14000000"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="itemBd" Property="Background" Value="#1A000000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 剪贴板文本 -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding DisplayText}"
                                           FontSize="12.5"
                                           Foreground="#222"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           LineHeight="18"
                                           LineStackingStrategy="BlockLineHeight"
                                           MaxHeight="54"
                                           VerticalAlignment="Center"/>

                                <!-- 删除按钮 (鼠标悬停显示) -->
                                <Button x:Name="DeleteBtn"
                                        Grid.Column="1"
                                        Content="✕"
                                        Style="{StaticResource ActionBtn}"
                                        Click="DeleteButton_Click"
                                        Tag="{Binding Id}"
                                        Visibility="Hidden"
                                        ToolTip="删除"/>
                            </Grid>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver,
                                             RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                             Value="True">
                                    <Setter TargetName="DeleteBtn" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 空列表提示 -->
                <TextBlock x:Name="EmptyPlaceholder"
                           Text="剪贴板历史为空"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#88000000"
                           FontSize="13"
                           Visibility="Collapsed"
                           IsHitTestVisible="False"/>
            </Grid>

            <!-- ══════════════════════════════════════════
                 底部状态栏 & 清空按钮
            ══════════════════════════════════════════ -->
            <Grid Grid.Row="2" Margin="10,0,10,0">
                <Button x:Name="ClearAllBtn"
                        Content="清空全部"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Width="66" Height="20"
                        FontSize="10.5"
                        Cursor="Hand"
                        Click="ClearAllButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#44000000"/>
                            <Setter Property="Foreground" Value="#444"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#14000000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="CountText" Text="0 项" FontSize="11" Foreground="#666"/>
                </StackPanel>
            </Grid>

            <!-- 右下角自定义 ResizeGrip -->
            <Grid Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,0">
                <Border x:Name="ResizeGripArea"
                        Width="12" Height="12"
                        Background="Transparent"
                        Cursor="SizeNWSE"
                        Opacity="0.4"
                        MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                        ToolTip="拖动调整大小">
                    <Canvas Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Line X1="10" Y1="4"  X2="4"  Y2="10" Stroke="#88888888" StrokeThickness="1.2" StrokeEndLineCap="Round"/>
                        <Line X1="10" Y1="7"  X2="7"  Y2="10" Stroke="#88888888" StrokeThickness="1.2" StrokeEndLineCap="Round"/>
                    </Canvas>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>
